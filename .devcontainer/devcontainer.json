{
    "name": "SDS210_Project",
    "image": "giswqs/pygis:latest",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter",
                "ms-azuretools.vscode-docker"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/opt/conda/bin/python",
                "jupyter.notebookEditor.defaultLanguage": "python"
            }
        }
    },
    "remoteUser": "root"
}